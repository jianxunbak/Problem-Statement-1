GEMINI_API_KEY=your_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# --- Vertex AI RAG (optional, set RAG_ENABLED=false to disable) ---
GOOGLE_CLOUD_PROJECT=your-project-id
RAG_ENABLED=false
VERTEX_DATASTORE_ID=scdf-fire-codes-poc

# --- Notion Export (optional — required for "export option to Notion") ---
# NOTION_API_KEY: Internal Integration Token from https://www.notion.so/my-integrations
# NOTION_DATABASE_ID: The 32-char ID from your Notion database URL
# NOTION_URL is a human-readable workspace link — not used by the API client
NOTION_API_KEY=your_notion_integration_token_here
NOTION_DATABASE_ID=your_32_char_database_id_here
