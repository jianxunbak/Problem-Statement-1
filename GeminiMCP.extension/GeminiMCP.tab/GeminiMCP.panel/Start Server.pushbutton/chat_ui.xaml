<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gemini MCP Chat" Height="600" Width="450"
        Background="#1E1E1E" Foreground="#FFFFFF" FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen"
        Topmost="True">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" BorderBrush="#333333" BorderThickness="0,0,0,1" Padding="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Gemini MCP Chat" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#E0E0E0"/>
                <TextBlock x:Name="StatusDot" Text=" ●" FontSize="14" VerticalAlignment="Center" Foreground="#4CAF50" Margin="10,0,0,0"/>
                <TextBlock x:Name="StatusText" Text="MCP Server Active" FontSize="12" VerticalAlignment="Center" Foreground="#AAAAAA" Margin="5,0,0,0"/>
            </StackPanel>
        </Border>

        <!-- Chat History Area -->
        <ScrollViewer Grid.Row="1" Name="ChatScroller" VerticalScrollBarVisibility="Auto" Margin="0,10,0,10">
            <StackPanel Name="ChatHistory" VerticalAlignment="Bottom">
                <Border Background="#2D2D2D" CornerRadius="8" Padding="12" HorizontalAlignment="Left" Margin="0,5,50,5">
                    <TextBlock Text="Hello! I am your Gemini-powered Revit assistant. The MCP server is running and I'm ready to help." TextWrapping="Wrap" MaxWidth="300" Foreground="#FFFFFF"/>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Input Area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Border Background="#2D2D2D" CornerRadius="20" Grid.Column="0" Padding="15,5">
                <TextBox Name="UserInput" 
                         Background="Transparent" 
                         Foreground="White" 
                         BorderThickness="0" 
                         VerticalAlignment="Center"
                         FontSize="14"
                         AcceptsReturn="False"
                         CaretBrush="White">
                </TextBox>
            </Border>

            <Button Name="SendButton" 
                    Grid.Column="1" 
                    Content="Send" 
                    Width="60" 
                    Height="35" 
                    Margin="10,0,0,0"
                    Background="#007ACC" 
                    Foreground="White" 
                    FontWeight="Bold"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="17"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button Name="StopButton" 
                    Grid.Column="2" 
                    Content="Stop" 
                    Width="60" 
                    Height="35" 
                    Margin="5,0,0,0"
                    Background="#B22222" 
                    Foreground="White" 
                    FontWeight="Bold"
                    Visibility="Collapsed"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="17"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Grid>
</Window>
